    // ===== HELPER: Get service key from URL =====
    function getServiceKey() {
      const params = new URLSearchParams(window.location.search);
      let service = params.get('service') || 'business';
      service = service.toLowerCase().trim().replace(/\s+/g, '');
      // Check if alias exists
      if (serviceAliases[service]) {
        service = serviceAliases[service];
      }
      // Check if service exists in data, fallback to business
      if (!serviceData[service]) {
        service = 'business';
      }
      return service;
    }

    // ===== HELPER: Related services with fallback =====
    function getRelatedServices(serviceKey) {
      const data = serviceData[serviceKey];
      if (!data) return ['business', 'landing', 'portfolio', 'ecommerce', 'restaurant', 'clinic'];
      const related = data.related || [];
      // Map related keys, fallback to business if not found
      const mapped = related.map(key => {
        if (serviceData[key]) return key;
        return 'business';
      });
      // Ensure we have 6 unique services
      const unique = [...new Set(mapped)];
      while (unique.length < 6) {
        const fallbacks = ['business', 'landing', 'portfolio', 'ecommerce', 'restaurant', 'clinic'];
        for (const fb of fallbacks) {
          if (!unique.includes(fb)) unique.push(fb);
          if (unique.length >= 6) break;
        }
      }
      return unique.slice(0, 6);
    }

    // ===== RENDER PAGE =====
    function initPage() {
      const serviceKey = getServiceKey();
      const data = serviceData[serviceKey] || serviceData['business'];

      // Update SEO
      document.getElementById('dynamicTitle').textContent = `${data.name} – Smile AI Web Studio`;
      document.getElementById('dynamicDescription').content = data.desc;
      document.getElementById('dynamicCanonical').href = `https://web.smilefinancialsolution.com/service-details.html?service=${serviceKey}`;
      document.getElementById('ogTitle').content = `${data.name} – Smile AI Web Studio`;
      document.getElementById('ogDescription').content = data.desc;

      // Update Service Schema
      const serviceSchema = {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": data.name,
        "description": data.desc,
        "provider": {
          "@type": "Organization",
          "name": "Smile AI Web Studio"
        },
        "areaServed": "IN"
      };
      document.getElementById('jsonld-service').textContent = JSON.stringify(serviceSchema);

      // Update Breadcrumb
      const breadcrumbSchema = {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://web.smilefinancialsolution.com/" },
          { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://web.smilefinancialsolution.com/services.html" },
          { "@type": "ListItem", "position": 3, "name": data.name, "item": `https://web.smilefinancialsolution.com/service-details.html?service=${serviceKey}` }
        ]
      };
      document.getElementById('jsonld-breadcrumb').textContent = JSON.stringify(breadcrumbSchema);

      // Update FAQ Schema
      const faqSchema = {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": data.faq.map(item => ({
          "@type": "Question",
          "name": item.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.a
          }
        }))
      };
      document.getElementById('jsonld-faq').textContent = JSON.stringify(faqSchema);

      // HERO
      document.getElementById('heroBadge').textContent = data.badge;
      document.getElementById('heroTitle').innerHTML = data.title;
      document.getElementById('heroDesc').textContent = data.desc;
      document.getElementById('breadcrumbName').textContent = data.name;

      // OVERVIEW
      document.getElementById('overviewTitle').textContent = data.name + ' Overview';
      document.getElementById('overviewDesc').textContent = data.overview;
      document.getElementById('overviewDesc2').textContent = data.overview2 || '';
      const highlightsList = document.getElementById('overviewHighlights');
      highlightsList.innerHTML = '';
      data.highlights.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        highlightsList.appendChild(li);
      });

      // FEATURES
      const featuresGrid = document.getElementById('featuresGrid');
      featuresGrid.innerHTML = '';
      data.features.forEach(item => {
        const card = document.createElement('div');
        card.className = 'feature-card';
        card.innerHTML = `<span class="icon">${item.icon}</span><h3>${item.name}</h3>`;
        featuresGrid.appendChild(card);
      });
      document.getElementById('featuresSub').textContent = `Everything you need for your ${data.name.toLowerCase()}.`;

      // BENEFITS
      const benefitsGrid = document.getElementById('benefitsGrid');
      benefitsGrid.innerHTML = '';
      data.benefits.forEach(item => {
        const card = document.createElement('div');
        card.className = 'benefit-card';
        card.innerHTML = `<span class="icon">${item.icon}</span><h3>${item.name}</h3>`;
        benefitsGrid.appendChild(card);
      });
      document.getElementById('benefitsSub').textContent = `Why choose our ${data.name.toLowerCase()} services.`;

      // RELATED SERVICES
      const relatedGrid = document.getElementById('relatedGrid');
      relatedGrid.innerHTML = '';
      const relatedKeys = getRelatedServices(serviceKey);
      relatedKeys.forEach(key => {
        const relData = serviceData[key];
        if (relData) {
          const card = document.createElement('div');
          card.className = 'related-card';
          card.innerHTML = `<span class="icon">${relData.icon}</span><h3>${relData.name}</h3>`;
          card.addEventListener('click', () => {
            window.location.href = `service-details.html?service=${key}`;
          });
          relatedGrid.appendChild(card);
        }
      });

      // FAQ
      const faqContainer = document.getElementById('faqContainer');
      faqContainer.innerHTML = '';
      data.faq.forEach(item => {
        const div = document.createElement('div');
        div.className = 'faq-item';
        div.innerHTML = `
          <div class="faq-question">${item.q} <span>+</span></div>
          <div class="faq-answer">${item.a}</div>
        `;
        faqContainer.appendChild(div);
      });

      // Update demo form service field
      document.getElementById('demoService').value = data.name;

      console.log(`📄 Service details loaded: ${data.name} (${serviceKey})`);
    }

    // ===== SCROLL REVEAL =====
    const revealItems = document.querySelectorAll('.feature-card, .benefit-card, .why-item, .related-card, .faq-item, .process-step');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.08 });
    revealItems.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      revealObserver.observe(el);
    });

    console.log('🚀 service-details.html – Dynamic service page');
    console.log('📌 Supported services: ' + Object.keys(serviceData).join(', '));
    console.log('📌 Aliases: ' + Object.keys(serviceAliases).join(', '));
    console.log('🔮 Future Firestore integration ready.');
  </script>
