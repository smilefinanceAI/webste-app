  <style>
    /* ===== RESET & VARIABLES (Same as index.html) ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --primary: #2563EB;
      --secondary: #10B981;
      --accent: #F59E0B;
      --bg-white: #ffffff;
      --glass-bg: rgba(255,255,255,0.10);
      --shadow-soft: 0 20px 50px -12px rgba(0,0,0,0.06);
      --shadow-card: 0 12px 40px -8px rgba(0,0,0,0.04);
      --radius-lg: 18px;
      --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #ffffff;
      color: #0b1a33;
      line-height: 1.6;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }
    .container { max-width: 1280px; margin: 0 auto; padding: 0 28px; }

    /* ===== GLASS & UTILITY ===== */
    .glass {
      background: var(--glass-bg);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,0.20);
      box-shadow: 0 8px 32px rgba(0,0,0,0.04);
    }
    .badge-pill {
      background: var(--secondary);
      color: white;
      padding: 6px 18px;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
      display: inline-block;
      letter-spacing: 0.3px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 34px;
      border-radius: 60px;
      font-weight: 600;
      font-size: 1rem;
      border: none;
      cursor: pointer;
      transition: var(--transition);
      position: relative;
      overflow: hidden;
      box-shadow: 0 4px 14px rgba(37,99,235,0.15);
    }
    .btn-primary {
      background: linear-gradient(145deg, #2563EB, #1d4ed8);
      color: white;
    }
    .btn-primary:hover { transform: scale(1.03) translateY(-2px); box-shadow: 0 12px 30px rgba(37,99,235,0.30); }
    .btn-secondary {
      background: var(--secondary);
      color: white;
    }
    .btn-secondary:hover { transform: scale(1.03) translateY(-2px); background: #059669; }
    .btn-outline {
      background: transparent;
      border: 2px solid var(--primary);
      color: var(--primary);
    }
    .btn-outline:hover { background: var(--primary); color: white; }
    .btn-accent {
      background: var(--accent);
      color: #0b1a33;
    }
    .btn-accent:hover { transform: scale(1.03) translateY(-2px); background: #d48d0a; }
    .btn-sm {
      padding: 8px 20px;
      border-radius: 60px;
      font-size: 0.85rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: var(--transition);
    }
    .btn-sm-primary { background: var(--primary); color: white; }
    .btn-sm-primary:hover { background: #1d4ed8; transform: scale(1.02); }
    .btn-sm-outline { background: transparent; border: 1px solid var(--primary); color: var(--primary); }
    .btn-sm-outline:hover { background: var(--primary); color: white; }
    .section-title {
      font-size: 2.8rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 0.5rem;
    }
    .section-title span { color: var(--primary); }
    .section-sub {
      font-size: 1.2rem;
      color: #475569;
      max-width: 600px;
    }
    .text-center { text-align: center; }
    .flex-center { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .mt-4 { margin-top: 2rem; }
    .mb-4 { margin-bottom: 2rem; }

    /* ===== LOADER ===== */
    #loader {
      position: fixed; inset: 0; background: white; z-index: 9999;
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.6s ease;
    }
    #loader.hide { opacity: 0; pointer-events: none; }
    .loader-spinner {
      width: 48px; height: 48px; border: 4px solid #e2e8f0;
      border-top-color: var(--primary); border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ===== HEADER ===== */
    header {
      position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
      padding: 16px 0; transition: var(--transition);
      background: rgba(255,255,255,0.70); backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0,0,0,0.03);
    }
    header.scrolled {
      background: rgba(255,255,255,0.94); box-shadow: 0 4px 24px rgba(0,0,0,0.03);
    }
    .header-inner {
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-size: 1.6rem; font-weight: 800; color: var(--primary);
      letter-spacing: -0.02em; display: flex; align-items: center; gap: 6px;
    }
    .logo span { color: var(--secondary); }
    .logo small { font-size: 0.6rem; font-weight: 500; color: #475569; background: #eef2f6; padding: 2px 10px; border-radius: 100px; margin-left: 6px; }
    nav { display: flex; align-items: center; gap: 2rem; }
    nav a {
      font-weight: 500; font-size: 0.95rem; color: #1e293b;
      transition: var(--transition); position: relative;
    }
    nav a:hover { color: var(--primary); }
    nav a::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 0; height: 2px; background: var(--primary);
      transition: var(--transition);
    }
    nav a:hover::after { width: 100%; }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .hamburger span { width: 28px; height: 3px; background: #1e293b; border-radius: 4px; transition: var(--transition); }

    /* ===== HERO ===== */
    #service-hero {
      padding: 140px 0 70px;
      background: linear-gradient(165deg, #f0f7ff 0%, #ffffff 100%);
      position: relative; overflow: hidden;
    }
    #service-hero .container {
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
      align-items: center;
    }
    .hero-content h1 {
      font-size: 3.2rem; font-weight: 900; line-height: 1.1; letter-spacing: -0.03em;
    }
    .hero-content h1 .highlight { color: var(--primary); }
    .hero-content p {
      font-size: 1.2rem; color: #334155; margin: 1.5rem 0 2rem;
      max-width: 520px;
    }
    .breadcrumb { font-size: 0.9rem; color: #475569; margin-top: 1rem; }
    .breadcrumb a { color: var(--primary); }
    .breadcrumb span { color: #94a3b8; }
    .hero-illustration {
      background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400"><circle cx="200" cy="200" r="160" fill="%232563EB" opacity="0.05"/><circle cx="200" cy="200" r="120" fill="%2310B981" opacity="0.04"/><circle cx="200" cy="200" r="80" fill="%23F59E0B" opacity="0.06"/><rect x="145" y="115" width="110" height="130" rx="16" fill="white" stroke="%232563EB" stroke-width="2.5"/><rect x="165" y="135" width="70" height="14" rx="8" fill="%232563EB"/><rect x="165" y="165" width="70" height="8" rx="4" fill="%23cbd5e1"/><rect x="165" y="185" width="70" height="8" rx="4" fill="%23cbd5e1"/><rect x="165" y="205" width="45" height="8" rx="4" fill="%23cbd5e1"/><circle cx="110" cy="95" r="28" fill="%23F59E0B" opacity="0.20"/><circle cx="320" cy="295" r="22" fill="%2310B981" opacity="0.15"/></svg>');
      background-size: contain; background-repeat: no-repeat; background-position: center;
      min-height: 280px; width: 100%;
    }
    .floating-shapes {
      position: absolute; inset: 0; pointer-events: none;
    }
    .floating-shapes span {
      position: absolute; border-radius: 50%; background: var(--primary); opacity: 0.04;
      animation: float 12s infinite alternate ease-in-out;
    }
    .floating-shapes span:nth-child(1) { width: 120px; height: 120px; top: 5%; left: 2%; }
    .floating-shapes span:nth-child(2) { width: 160px; height: 160px; bottom: 5%; right: 3%; background: var(--accent); animation-delay: 0.5s; }
    .floating-shapes span:nth-child(3) { width: 80px; height: 80px; top: 50%; right: 0%; background: var(--secondary); animation-delay: 1s; }
    @keyframes float { 0% { transform: translateY(0px) rotate(0deg); } 100% { transform: translateY(-40px) rotate(10deg); } }

    /* ===== OVERVIEW ===== */
    #overview { padding: 80px 0; background: white; }
    .overview-grid {
      display: grid; grid-template-columns: 2fr 1fr; gap: 3rem;
      align-items: start;
    }
    .overview-content p { font-size: 1.1rem; color: #475569; }
    .overview-highlights {
      background: #f8fafc; padding: 2rem; border-radius: var(--radius-lg);
      border: 1px solid #eef2f6;
    }
    .overview-highlights li { list-style: none; padding: 8px 0; border-bottom: 1px solid #eef2f6; }
    .overview-highlights li:last-child { border-bottom: none; }
    .overview-highlights li::before { content: "✓ "; color: var(--secondary); font-weight: 700; }

    /* ===== FEATURES ===== */
    #features { padding: 80px 0; background: #f8fafc; }
    .features-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 2rem; margin-top: 2rem;
    }
    .feature-card {
      background: white; padding: 2rem; border-radius: var(--radius-lg);
      border: 1px solid #eef2f6; text-align: center; transition: var(--transition);
    }
    .feature-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
    .feature-card .icon { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }
    .feature-card h3 { font-weight: 700; font-size: 1.1rem; }

    /* ===== BENEFITS ===== */
    #benefits { padding: 80px 0; background: white; }
    .benefits-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 2rem; margin-top: 2rem;
    }
    .benefit-card {
      background: #f8fafc; padding: 1.5rem; border-radius: var(--radius-lg);
      text-align: center; border: 1px solid #eef2f6; transition: var(--transition);
    }
    .benefit-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
    .benefit-card .icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }

    /* ===== PROCESS ===== */
    #process { padding: 80px 0; background: #f8fafc; }
    .process-steps {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 1.5rem;
      margin-top: 2rem;
    }
    .process-step {
      background: white; padding: 1.5rem; border-radius: var(--radius-lg);
      text-align: center; border: 1px solid #eef2f6; transition: var(--transition);
    }
    .process-step:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
    .process-step .num { font-size: 2rem; font-weight: 800; color: var(--primary); opacity: 0.15; }
    .process-step h3 { font-weight: 700; font-size: 0.9rem; margin: 0.5rem 0; }

    /* ===== WHY CHOOSE ===== */
    #why-choose { padding: 80px 0; background: white; }
    .why-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 2rem; margin-top: 2rem;
    }
    .why-item {
      background: #f8fafc; padding: 1.5rem; border-radius: var(--radius-lg);
      text-align: center; font-weight: 600; border: 1px solid #eef2f6;
      transition: var(--transition);
    }
    .why-item:hover { background: var(--primary); color: white; transform: scale(1.02); }

    /* ===== RELATED SERVICES ===== */
    #related { padding: 80px 0; background: #f8fafc; }
    .related-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 2rem; margin-top: 2rem;
    }
    .related-card {
      background: white; padding: 1.5rem; border-radius: var(--radius-lg);
      text-align: center; border: 1px solid #eef2f6; transition: var(--transition);
      cursor: pointer;
    }
    .related-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); border-color: var(--primary); }
    .related-card .icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
    .related-card h3 { font-weight: 700; font-size: 1rem; }

    /* ===== FAQ ===== */
    #faq { padding: 80px 0; background: white; }
    .faq-item {
      background: #f8fafc; border-radius: 16px; margin-bottom: 1rem;
      padding: 1.2rem 1.5rem; cursor: pointer; border: 1px solid #eef2f6;
      transition: var(--transition);
    }
    .faq-item:hover { border-color: var(--primary); }
    .faq-question { display: flex; justify-content: space-between; font-weight: 600; }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; color: #475569; }
    .faq-item.active .faq-answer { max-height: 200px; padding-top: 0.75rem; }

    /* ===== DEMO FORM ===== */
    #demo-form { padding: 80px 0; background: #f8fafc; }
    .form-wrapper {
      max-width: 700px; margin: 0 auto; background: white; padding: 2.5rem;
      border-radius: var(--radius-lg); border: 1px solid #eef2f6; box-shadow: var(--shadow-card);
    }
    .form-wrapper input, .form-wrapper textarea, .form-wrapper select {
      width: 100%; padding: 14px 18px; border-radius: 60px; border: 1px solid #d1d9e6;
      font-size: 1rem; margin-bottom: 1rem; background: white;
      transition: var(--transition);
    }
    .form-wrapper input:focus, .form-wrapper textarea:focus, .form-wrapper select:focus {
      outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.08);
    }
    .form-wrapper textarea { border-radius: 24px; min-height: 80px; resize: vertical; }

    /* ===== FINAL CTA ===== */
    #final-cta {
      padding: 80px 0; background: linear-gradient(145deg, #2563EB, #1d4ed8);
      color: white; text-align: center;
    }
    #final-cta h2 { font-size: 2.8rem; font-weight: 800; }
    #final-cta .btn { box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

    /* ===== FOOTER ===== */
    footer {
      background: #0b1a33; color: #cbd5e1; padding: 3rem 0;
    }
    footer .container { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; }
    footer a { display: block; margin: 6px 0; transition: var(--transition); }
    footer a:hover { color: white; padding-left: 4px; }
    footer .powered { margin-top: 2rem; border-top: 1px solid #1e293b; padding-top: 1.5rem; text-align: center; }

    /* ===== FLOATING BUTTONS ===== */
    .floating-btn {
      position: fixed; right: 24px; z-index: 999;
      width: 56px; height: 56px; border-radius: 60px;
      background: var(--primary); color: white; border: none;
      box-shadow: 0 8px 24px rgba(37,99,235,0.25);
      font-size: 1.5rem; cursor: pointer; transition: var(--transition);
      display: flex; align-items: center; justify-content: center;
    }
    .floating-btn:hover { transform: scale(1.08); }
    .floating-btn.whatsapp { bottom: 100px; background: #25D366; }
    .floating-btn.call { bottom: 170px; background: var(--secondary); }
    .floating-btn.top { bottom: 30px; background: var(--accent); color: #0b1a33; }

    /* ===== THANK YOU POPUP ===== */
    .popup-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.35); backdrop-filter: blur(6px);
      z-index: 2000; display: none; align-items: center; justify-content: center;
      padding: 20px;
    }
    .popup-overlay.open { display: flex; }
    .popup {
      background: white; max-width: 460px; width: 100%; padding: 2.5rem;
      border-radius: var(--radius-lg); box-shadow: var(--shadow-soft);
      text-align: center; animation: popIn 0.3s ease;
    }
    @keyframes popIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    .popup .close {
      position: absolute; top: 16px; right: 20px; font-size: 1.8rem; cursor: pointer;
      color: #94a3b8; transition: var(--transition);
    }
    .popup .close:hover { color: #1e293b; }
    .popup .icon-big { font-size: 4rem; margin-bottom: 0.5rem; }
    .popup h2 { font-weight: 800; margin-bottom: 0.5rem; }
    .popup .btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      #service-hero .container { grid-template-columns: 1fr; text-align: center; }
      .hero-content p { margin-left: auto; margin-right: auto; }
      .overview-grid { grid-template-columns: 1fr; }
      .process-steps { grid-template-columns: repeat(3, 1fr); }
      footer .container { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      nav { display: none; }
      .hamburger { display: flex; }
      nav.open { display: flex; flex-direction: column; position: absolute; top: 70px; left: 0; width: 100%; background: white; padding: 2rem; gap: 1rem; box-shadow: var(--shadow-soft); border-radius: 0 0 24px 24px; }
      .hero-content h1 { font-size: 2.4rem; }
      .section-title { font-size: 2rem; }
      .process-steps { grid-template-columns: 1fr 1fr; }
      footer .container { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .hero-content h1 { font-size: 2rem; }
      .btn { padding: 12px 24px; font-size: 0.9rem; }
      .process-steps { grid-template-columns: 1fr; }
      .floating-btn { width: 48px; height: 48px; font-size: 1.2rem; right: 16px; }
      .form-wrapper { padding: 1.5rem; }
    }
  </style>
</head>
